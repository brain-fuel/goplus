(*
  G++ grammar, v0.1.0 — expressed as a delta over the Go specification
  (https://go.dev/ref/spec, "Method declarations").

  G++ is a strict superset of Go: every production not listed here is
  exactly the Go production. A .gpp file whose source uses no G++ extension
  is a valid Go file and passes through generation unchanged (plus header).

  This file and the Godog feature suite under features/ are together the
  authoritative specification of G++.
*)

(* ------------------------------------------------------------------ *)
(* Go (unchanged, for reference):                                      *)
(*   MethodDecl = "func" Receiver MethodName Signature [ FunctionBody ] . *)
(* ------------------------------------------------------------------ *)

(* G++ v0.1.0: a method may introduce type parameters of its own,       *)
(* not present on the receiver.                                         *)

MethodDecl = "func" Receiver MethodName [ TypeParameters ] Signature [ FunctionBody ] .

(*
  TypeParameters, Receiver, MethodName, Signature, FunctionBody are the Go
  productions, unchanged. Receiver type parameters (if the receiver's base
  type is generic) are declared on the Receiver exactly as in Go; method
  type parameters are additional and scoped to the method.

  Call sites need no grammar extension: `s.Map(f)` and the explicitly
  instantiated `s.Map[int](f)` are already syntactically valid Go
  (PrimaryExpr with Selector, Index/IndexList, Arguments). Method
  expressions/values `s.Map[int]` (without call) are likewise valid
  PrimaryExpr syntax; their G++ semantics are defined by the feature suite.

  Semantic notes (normative, enforced by the generator; specified in
  features/):

  - Lowering: `func (r R[T…]) M[U…](args…) results…` lowers to a
    package-level function `func RM[T… , U…](r R[T…], args…) results…`.
    Receiver type parameters precede method type parameters; explicit call
    instantiation therefore requires the generator to prefix the receiver's
    type arguments, which it derives from the receiver's static type.

  - Naming: generated name = concat(ReceiverBaseTypeName, MethodName),
    exported iff both parts are exported; otherwise first letter lowered.
    Any collision is a compile-time error, resolvable with the directive
    comment `//gpp:name NewName` on the method declaration.

  - Marker: each lowered function is preceded by a machine-readable
    comment `//gpp:method (R[T…]) M[U…]` (pointer receivers render as
    `(*R[T…])`). These markers are how importing packages discover generic
    methods in distributed, toolchain-free Go artifacts.
*)

(* Directive comments recognized by the generator (comments per Go spec): *)

GppNameDirective   = "//gpp:name"   identifier .
GppMethodMarker    = "//gpp:method" "(" [ "*" ] TypeName [ TypeParameters ] ")" MethodName [ TypeParameters ] .
